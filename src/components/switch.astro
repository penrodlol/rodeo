---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import { Text, type TextVariants } from './typography';

type Props = Omit<HTMLAttributes<'input'>, 'type' | 'role'> & SwitchVariants & { textVariants?: TextVariants };

export type SwitchVariants = VariantProps<typeof switchVariants>;

export const switchVariants = tv({
  slots: {
    base: 'flex w-fit items-center gap-2.5 select-none has-disabled:pointer-events-none has-disabled:opacity-50',
    control: [
      '@container flex shrink-0 appearance-none items-center overflow-hidden rounded-full border border-transparent px-0.5',
      'checked:border-transparent disabled:pointer-events-none disabled:opacity-50',
      'focus-visible:ring-accent-8 focus-visible:ring focus-visible:outline-none',
      'before:rounded-[inherit] before:shadow-md',
      'before:will-change-transform active:before:scale-[0.95]',
      'checked:before:translate-x-[calc(100cqw-100%)]',
      'rtl:checked:before:translate-x-[calc(-100cqw+100%)]',
      'motion-safe:transition-[background-color,color,border-color]',
      'motion-safe:before:transition-[background-color,color,translate,scale]',
    ],
  },
  defaultVariants: { size: '2', variant: 'gray-accent-soft-outline' },
  variants: {
    elevation: { '1': { control: 'elevation-1' }, '2': { control: 'elevation-2' }, '3': { control: 'elevation-3' } },
    size: {
      '1': { base: 'text-sm', control: 'h-4.5 w-7 before:size-3' },
      '2': { base: 'text-base', control: 'h-5 w-8 before:size-3.5' },
      '3': { base: 'text-lg', control: 'h-5.5 w-9 before:size-4' },
      '4': { base: 'text-xl', control: 'h-6 w-10 before:size-4.5' },
      '5': { base: 'text-2xl', control: 'h-6.5 w-11 before:size-5' },
    },
    // prettier-ignore
    variant: {
      'gray-surface': { control: 'bg-gray-1 text-gray-11 checked:bg-gray-9 before:bg-gray-contrast' },
      'gray-solid': { control: 'bg-gray-9 text-gray-contrast checked:bg-gray-9 before:bg-gray-contrast' },
      'gray-soft': { control: 'bg-gray-3 text-gray-11 checked:bg-gray-9 before:bg-gray-contrast' },
      'gray-soft-outline': { control: 'bg-gray-3 text-gray-11 border-gray-7 border checked:bg-gray-9 before:bg-gray-contrast' },
      'gray-surface-outline': { control: 'bg-gray-1 text-gray-11 border-gray-7 border checked:bg-gray-9 before:bg-gray-contrast' },
      'gray-ghost-outline': { control: 'text-gray-11 border-gray-7 border checked:bg-gray-9 before:bg-gray-contrast' },
      'gray-accent-surface': { control: 'bg-gray-1 text-gray-11 checked:bg-accent-9 before:bg-gray-contrast' },
      'gray-accent-solid': { control: 'bg-gray-9 text-gray-contrast checked:bg-accent-9 before:bg-gray-contrast' },
      'gray-accent-soft': { control: 'bg-gray-3 text-gray-11 checked:bg-accent-9 before:bg-gray-contrast' },
      'gray-accent-soft-outline': { control: 'bg-gray-3 text-gray-11 border-gray-7 border checked:bg-accent-9 before:bg-gray-contrast' },
      'gray-accent-surface-outline': { control: 'bg-gray-1 text-gray-11 border-gray-7 border checked:bg-accent-9 before:bg-gray-contrast' },
      'gray-accent-ghost-outline': { control: 'text-gray-11 border-gray-7 border checked:bg-accent-9 before:bg-gray-contrast' },
      'accent-surface': { control: 'bg-accent-1 text-accent-11 checked:bg-accent-9 before:bg-accent-contrast', },
      'accent-solid': { control: 'bg-accent-9 text-accent-contrast checked:bg-accent-9 before:bg-accent-contrast' },
      'accent-soft': { control: 'bg-accent-3 text-accent-11 checked:bg-accent-9 before:bg-accent-contrast' },
      'accent-soft-outline': { control: 'bg-accent-3 text-accent-11 border-accent-7 border checked:bg-accent-9 before:bg-accent-contrast' },
      'accent-surface-outline': { control: 'bg-accent-1 text-accent-11 border-accent-7 border checked:bg-accent-9 before:bg-accent-contrast' },
      'accent-ghost-outline': { control: 'text-accent-11 border-accent-7 border checked:bg-accent-9 before:bg-accent-contrast' },
      'warn-surface': { control: 'bg-warn-1 text-warn-11 checked:bg-warn-9 before:bg-warn-contrast focus-visible:ring-warn-8' },
      'warn-solid': { control: 'bg-warn-9 text-warn-contrast checked:bg-warn-9 before:bg-warn-contrast focus-visible:ring-warn-8' },
      'warn-soft': { control: 'bg-warn-3 text-warn-11 checked:bg-warn-9 before:bg-warn-contrast focus-visible:ring-warn-8' },
      'warn-soft-outline': { control: 'bg-warn-3 text-warn-11 border-warn-7 border checked:bg-warn-9 before:bg-warn-contrast focus-visible:ring-warn-8' },
      'warn-surface-outline': { control: 'bg-warn-1 text-warn-11 border-warn-7 border checked:bg-warn-9 before:bg-warn-contrast focus-visible:ring-warn-8' },
      'warn-ghost-outline': { control: 'text-warn-11 border-warn-7 border checked:bg-warn-9 before:bg-warn-contrast focus-visible:ring-warn-8' },
      'danger-surface': { control: 'bg-danger-1 text-danger-11 checked:bg-danger-9 before:bg-danger-contrast focus-visible:ring-danger-8' },
      'danger-solid': { control: 'bg-danger-9 text-danger-contrast checked:bg-danger-9 before:bg-danger-contrast focus-visible:ring-danger-8' },
      'danger-soft': { control: 'bg-danger-3 text-danger-11 checked:bg-danger-9 before:bg-danger-contrast focus-visible:ring-danger-8' },
      'danger-soft-outline': { control: 'bg-danger-3 text-danger-11 border-danger-7 border checked:bg-danger-9 before:bg-danger-contrast focus-visible:ring-danger-8' },
      'danger-surface-outline': { control: 'bg-danger-1 text-danger-11 border-danger-7 border checked:bg-danger-9 before:bg-danger-contrast focus-visible:ring-danger-8' },
      'danger-ghost-outline': { control: 'text-danger-11 border-danger-7 border checked:bg-danger-9 before:bg-danger-contrast focus-visible:ring-danger-8' },
    },
  },
});

const { class: className, elevation, size, variant, textVariants, ...props } = Astro.props;
const Tag = Astro.slots.has('default') ? 'label' : Fragment;
const slots = switchVariants({ elevation, size, variant });
---

<Tag data-slot="switch" class={slots.base({ className })}>
  <Text as={Astro.slots.has('default') ? 'span' : Fragment} trim size="inherit" {...textVariants}><slot /></Text>
  <input data-slot="field-control" type="checkbox" role="switch" class={slots.control()} {...props} />
</Tag>
