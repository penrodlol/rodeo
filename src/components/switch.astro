---
import { getComponentVariants } from '@/libs/variant';
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import { Text, type TextVariants } from './typography';

type Props = Omit<HTMLAttributes<'input'>, 'type' | 'role'> & SwitchVariants & { textVariants?: TextVariants };

export type SwitchVariants = VariantProps<typeof switchVariants>;

export const componentVariants = getComponentVariants({ slot: 'control' });
export const switchVariants = tv({
  extend: componentVariants.variants,
  slots: {
    base: 'flex w-fit items-center gap-2.5 select-none has-disabled:pointer-events-none has-disabled:opacity-50',
    control: [
      '@container flex shrink-0 appearance-none items-center overflow-hidden rounded-full px-0.5',
      'border border-transparent checked:border-transparent',
      'before:rounded-[inherit] before:bg-current before:shadow-md',
      'before:will-change-transform active:before:scale-[0.95]',
      'checked:before:translate-x-[calc(100cqw-100%)]',
      'rtl:checked:before:translate-x-[calc(-100cqw+100%)]',
      'focus-visible:ring focus-visible:outline-none',
      'disabled:pointer-events-none disabled:opacity-50',
      'motion-safe:transition-[background-color,color,border-color]',
      'motion-safe:before:transition-[background-color,color,translate,scale]',
    ],
  },
  defaultVariants: { size: '2', variant: 'gray-accent-soft-outline' },
  variants: {
    size: {
      '1': { base: 'text-sm', control: 'h-4 w-7 before:size-2.5' },
      '2': { base: 'text-base', control: 'h-4.5 w-8 before:size-3' },
      '3': { base: 'text-lg', control: 'h-5 w-9 before:size-3.5' },
      '4': { base: 'text-xl', control: 'h-5.5 w-10 before:size-4' },
      '5': { base: 'text-2xl', control: 'h-6 w-11 before:size-4.5' },
    },
  },
  compoundVariants: [
    { variant: componentVariants.keys.gray, class: { control: 'checked:bg-gray-9 before:bg-gray-contrast' } },
    { variant: componentVariants.keys.grayAccent, class: { control: 'checked:bg-accent-9 before:bg-accent-contrast' } },
    { variant: componentVariants.keys.grayWarn, class: { control: 'checked:bg-warn-9 before:bg-warn-contrast' } },
    { variant: componentVariants.keys.grayDanger, class: { control: 'checked:bg-danger-9 before:bg-danger-contrast' } },
    { variant: componentVariants.keys.accent, class: { control: 'checked:bg-accent-9 before:bg-accent-contrast' } },
    { variant: componentVariants.keys.warn, class: { control: 'checked:bg-warn-9 before:bg-warn-contrast' } },
    { variant: componentVariants.keys.danger, class: { control: 'checked:bg-danger-9 before:bg-danger-contrast' } },
  ],
});

const { class: className, elevation, variant, size, textVariants, ...props } = Astro.props;
const Tag = Astro.slots.has('default') ? 'label' : Fragment;
const slots = switchVariants({ elevation, variant, size });
---

<Tag data-slot="switch" class={slots.base({ className })}>
  <Text as={Astro.slots.has('default') ? 'span' : Fragment} trim size="inherit" {...textVariants}><slot /></Text>
  <input data-slot="field-control" type="checkbox" role="switch" class={slots.control()} {...props} />
</Tag>
