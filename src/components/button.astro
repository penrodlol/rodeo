---
import { getComponentVariants } from '@/libs/variant';
import type { ComponentProps, HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import Icon from './icon.astro';
import { Text } from './typography';

type Props = HTMLAttributes<'button'> & ButtonVariants;

export type ButtonVariants = VariantProps<typeof buttonVariants> & { icon?: ComponentProps<typeof Icon> };

export const buttonVariants = tv({
  extend: getComponentVariants({ hover: true }).variants,
  slots: {
    base: [
      'inline-flex items-center justify-center gap-2 rounded font-medium',
      'whitespace-nowrap will-change-transform select-none',
      'focus-visible:ring focus-visible:outline-none',
      'disabled:pointer-events-none disabled:opacity-50',
      'motion-safe:transition-[background-color,color,scale] motion-safe:active:scale-[0.97]',
    ],
    icon: '',
  },
  defaultVariants: { size: '2', variant: 'accent-solid' },
  variants: {
    iconPosition: { prefix: 'flex-row', suffix: 'flex-row-reverse' },
    size: {
      '1': { base: 'h-7.5 px-3 text-sm', icon: 'size-3 opacity-80' },
      '2': { base: 'h-8.5 px-4 text-base', icon: 'size-4 opacity-80' },
      '3': { base: 'h-9.5 px-5 text-lg', icon: 'size-5 opacity-80' },
      '4': { base: 'h-11.5 px-7 text-xl', icon: 'size-6 opacity-80' },
      '5': { base: 'h-12.5 px-8 text-2xl', icon: 'size-7 opacity-80' },
      '1-icon': { base: 'size-7 shrink-0', icon: 'size-3' },
      '2-icon': { base: 'size-8 shrink-0', icon: 'size-4' },
      '3-icon': { base: 'size-9 shrink-0', icon: 'size-5' },
      '4-icon': { base: 'size-11 shrink-0', icon: 'size-6' },
      '5-icon': { base: 'size-12 shrink-0', icon: 'size-7' },
    },
  },
});

const { class: className, elevation, variant, iconPosition, size, icon, ...props } = Astro.props;
const slots = buttonVariants({ elevation, variant, iconPosition, size });
---

<button data-slot="button" type="button" class={slots.base({ className })} {...props}>
  {icon && <Icon class={slots.icon()} {...icon} />}
  <Text as={Astro.slots.has('default') && !!icon ? 'span' : Fragment} trim size="inherit"><slot /></Text>
</button>
