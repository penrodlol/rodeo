---
import { Text, type TextVariants } from '@/components/typography';
import { getComponentVariants } from '@/libs/variant';
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';

type Props = Omit<HTMLAttributes<'input'>, 'type' | 'name'> & RadioGroupRadioVariants & { textVariants?: TextVariants };

export type RadioGroupRadioVariants = VariantProps<typeof radioGroupRadioVariants>;

export const componentVariants = getComponentVariants({ slot: 'control', focus: true });
export const radioGroupRadioVariants = tv({
  extend: componentVariants.variants,
  slots: {
    base: 'flex w-fit items-center gap-2.5 select-none has-disabled:pointer-events-none has-disabled:opacity-50',
    control: [
      'relative flex shrink-0 appearance-none items-center justify-center overflow-hidden rounded-full will-change-transform',
      'focus-visible:ring focus-visible:outline-none',
      'disabled:pointer-events-none disabled:opacity-50',
      'checked:border-transparent not-checked:active:scale-[0.95]',
      'before:absolute before:inset-0 before:rounded-[inherit] before:shadow-md',
      'not-checked:before:scale-0 checked:before:scale-40',
      'motion-safe:transition-all motion-safe:before:transition-all',
    ],
  },
  defaultVariants: { size: '2', variant: 'gray-accent-soft-outline' },
  variants: {
    radioPosition: { prefix: 'flex-row', suffix: 'flex-row-reverse' },
    size: {
      '1': { base: 'text-sm [&+[data-slot="field-description"]]:ml-6', control: 'size-3.5' },
      '2': { base: 'text-base [&+[data-slot="field-description"]]:ml-6.5', control: 'size-4' },
      '3': { base: 'text-lg [&+[data-slot="field-description"]]:ml-7', control: 'size-4.5' },
      '4': { base: 'text-xl [&+[data-slot="field-description"]]:ml-7.5', control: 'size-5' },
      '5': { base: 'text-2xl [&+[data-slot="field-description"]]:ml-8', control: 'size-5.5' },
    },
  },
  compoundVariants: [
    { variant: componentVariants.keys.gray, class: { control: 'checked:bg-gray-9 before:bg-gray-contrast' } },
    { variant: componentVariants.keys.grayAccent, class: { control: 'checked:bg-accent-9 before:bg-accent-contrast' } },
    { variant: componentVariants.keys.grayWarn, class: { control: 'checked:bg-warn-9 before:bg-warn-contrast' } },
    { variant: componentVariants.keys.grayDanger, class: { control: 'checked:bg-danger-9 before:bg-danger-contrast' } },
    { variant: componentVariants.keys.accent, class: { control: 'checked:bg-accent-9 before:bg-accent-contrast' } },
    { variant: componentVariants.keys.warn, class: { control: 'checked:bg-warn-9 before:bg-warn-contrast' } },
    { variant: componentVariants.keys.danger, class: { control: 'checked:bg-danger-9 before:bg-danger-contrast' } },
  ],
});

const { class: className, elevation, variant, radioPosition, size, textVariants, ...props } = Astro.props;
const Tag = Astro.slots.has('default') ? 'label' : Fragment;
const slots = radioGroupRadioVariants({ elevation, variant, radioPosition, size });
---

<Tag data-slot="radio-group-radio" class={slots.base({ className })}>
  <input data-slot="field-control" type="radio" class={slots.control()} {...props} />
  <Text as={Astro.slots.has('default') ? 'span' : Fragment} trim size="inherit" {...textVariants}><slot /></Text>
</Tag>
