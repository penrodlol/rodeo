---
import Icon from '@/components/icon.astro';
import Surface, { surfaceVariants, surfaceVariantsVariantKeys } from '@/components/surface.astro';
import { componentProvider } from '@/libs/component';
import type { ComponentProps } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';

type Props = Omit<ComponentProps<typeof Surface<'aside'>>, 'as'> &
  NoteVariants & { type?: NoteType; icon?: ComponentProps<typeof Icon> };

export type NoteVariants = VariantProps<typeof noteVariants>;
export type NoteType = keyof typeof iconMapper;

export const noteVariants = tv({
  slots: {
    base: [
      'grid grid-cols-[auto_1fr] items-center p-4',
      '[grid-template-areas:"icon_title"_"content_content"]',
      'has-data-[slot="note-content"]:gap-y-2.5',
      'has-data-[slot="note-content"]:*:data-[slot="note-title"]:font-semibold',
    ],
    icon: '[grid-area:icon]',
    title: '[grid-area:title]',
    content: '[grid-area:content]',
  },
  defaultVariants: { rounded: true, size: '2', variant: 'gray-soft-outline' },
  variants: {
    ...surfaceVariants.variants,
    iconHidden: { false: 'gap-x-2' },
    size: {
      '1': { base: 'text-sm', icon: 'size-3.5', content: '[&,*]:text-xs' },
      '2': { base: 'text-base', icon: 'size-4', content: '[&,*]:text-sm' },
      '3': { base: 'text-lg', icon: 'size-4.5', content: '[&,*]:text-base' },
      '4': { base: 'text-xl', icon: 'size-5', content: '[&,*]:text-lg' },
      '5': { base: 'text-2xl', icon: 'size-5.5', content: '[&,*]:text-xl' },
    },
  },
  // prettier-ignore
  compoundVariants: [
    { variant: surfaceVariantsVariantKeys.gray, class: { base: 'text-gray-11', content: 'text-gray-12' } },
    { variant: surfaceVariantsVariantKeys.accent, class: { base: 'text-accent-11', content: 'text-accent-12' } },
    { variant: surfaceVariantsVariantKeys.warn, class: { base: 'text-warn-11 selection:bg-warn-5', content: 'text-warn-12' } },
    { variant: surfaceVariantsVariantKeys.danger, class: { base: 'text-danger-11 selection:bg-danger-5', content: 'text-danger-12' } },
  ],
});

const { class: className, rounded, elevation, variant, iconHidden, size, icon, type, ...props } = Astro.props;
const slots = noteVariants({ rounded, elevation, variant, iconHidden, size });
const iconMapper = { info: 'info', tip: 'lightbulb', warn: 'alert-triangle', danger: 'alert-octagon' };

const provider = componentProvider.create(await Astro.slots.render('default'));
const id = String(provider.getSlotProps('note-title')?.id ?? provider.generateId());

provider.provideContext({
  'note-title': ({ id: titleId, className }) => ({ id: titleId ?? id, className: slots.title({ className }) }),
  'note-content': ({ className }) => ({ className: slots.content({ className }) }),
});
---

<aside data-slot="note" aria-labelledby={id} class={slots.base({ className })} set:html={provider.render()} {...props}>
  {!iconHidden && <Icon name={iconMapper[type ?? 'info']} class={slots.icon()} {...icon} />}
</aside>
