---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';

type Props = HTMLAttributes<'textarea'> & TextAreaVariants;

export type TextAreaVariants = VariantProps<typeof textareaVariants>;

export const textareaVariants = tv({
  base: [
    'w-full rounded border px-4 py-2 select-none',
    'focus-visible:outline-none disabled:pointer-events-none disabled:opacity-50',
    'user-invalid:border-danger-7 user-invalid:focus-visible:border-danger-8',
  ],
  defaultVariants: { resize: 'auto', size: '2', variant: 'gray-ghost-outline' },
  variants: {
    resize: { true: 'resize-y', false: 'resize-none', auto: 'field-sizing-content resize-none' },
    elevation: { '1': 'elevation-1', '2': 'elevation-2', '3': 'elevation-3' },
    size: {
      '1': 'min-h-12 text-sm',
      '2': 'min-h-16 text-base',
      '3': 'min-h-20 text-lg',
      '4': 'min-h-24 text-xl',
      '5': 'min-h-28 text-2xl',
    },
    // prettier-ignore
    variant: {
      'gray-surface': 'bg-gray-1 placeholder:text-gray-11/70 focus-visible:border-accent-8 border-transparent',
      'gray-ghost': 'border-transparent placeholder:text-gray-11/70 focus-visible:border-accent-8 bg-transparent',
      'gray-solid': 'bg-gray-9 placeholder:text-gray-contrast/70 focus-visible:border-accent-8 border-transparent',
      'gray-soft': 'bg-gray-3 placeholder:text-gray-11/70 focus-visible:border-accent-8 border-transparent',
      'gray-soft-outline': 'bg-gray-3 border-gray-7 placeholder:text-gray-11/70 focus-visible:border-accent-8',
      'gray-surface-outline': 'bg-gray-1 border-gray-7 placeholder:text-gray-11/70 focus-visible:border-accent-8',
      'gray-ghost-outline': 'border-gray-7 placeholder:text-gray-11/70 focus-visible:border-accent-8 bg-transparent',
      'accent-surface': 'bg-accent-1 text-accent-12 placeholder:text-accent-11/70 focus-visible:border-accent-8 border-transparent',
      'accent-ghost': 'text-accent-12 border-transparent placeholder:text-accent-11/70 focus-visible:border-accent-8 bg-transparent',
      'accent-solid': 'text-accent-contrast bg-accent-9 placeholder:text-accent-contrast/70 focus-visible:border-accent-8 border-transparent',
      'accent-soft': 'bg-accent-3 text-accent-12 placeholder:text-accent-11/70 focus-visible:border-accent-8 border-transparent',
      'accent-soft-outline': 'bg-accent-3 text-accent-12 border-accent-7 placeholder:text-accent-11/70 focus-visible:border-accent-8',
      'accent-surface-outline': 'bg-accent-1 text-accent-12 border-accent-7 placeholder:text-accent-11/70 focus-visible:border-accent-8',
      'accent-ghost-outline': 'text-accent-12 border-accent-7 placeholder:text-accent-11/70 focus-visible:border-accent-8 bg-transparent',
      'warn-surface': 'bg-warn-1 text-warn-12 placeholder:text-warn-11/70 focus-visible:border-warn-8 border-transparent',
      'warn-ghost': 'text-warn-12 border-transparent placeholder:text-warn-11/70 focus-visible:border-warn-8 bg-transparent',
      'warn-solid': 'bg-warn-9 text-warn-contrast placeholder:text-warn-contrast/70 focus-visible:border-warn-8 border-transparent',
      'warn-soft': 'bg-warn-3 text-warn-12 placeholder:text-warn-11/70 focus-visible:border-warn-8 border-transparent',
      'warn-soft-outline': 'bg-warn-3 text-warn-12 border-warn-7 placeholder:text-warn-11/70 focus-visible:border-warn-8',
      'warn-surface-outline': 'bg-warn-1 text-warn-12 border-warn-7 placeholder:text-warn-11/70 focus-visible:border-warn-8',
      'warn-ghost-outline': 'text-warn-12 border-warn-7 placeholder:text-warn-11/70 focus-visible:border-warn-8 bg-transparent',
      'danger-surface': 'bg-danger-1 text-danger-12 placeholder:text-danger-11/70 focus-visible:border-danger-8 border-transparent',
      'danger-ghost': 'text-danger-12 border-transparent placeholder:text-danger-11/70 focus-visible:border-danger-8 bg-transparent',
      'danger-solid': 'bg-danger-9 text-danger-contrast placeholder:text-danger-contrast/70 focus-visible:border-danger-8 border-transparent',
      'danger-soft': 'bg-danger-3 text-danger-12 placeholder:text-danger-11/70 focus-visible:border-danger-8 border-transparent',
      'danger-soft-outline': 'bg-danger-3 text-danger-12 border-danger-7 placeholder:text-danger-11/70 focus-visible:border-danger-8',
      'danger-surface-outline': 'bg-danger-1 text-danger-12 border-danger-7 placeholder:text-danger-11/70 focus-visible:border-danger-8',
      'danger-ghost-outline': 'text-danger-12 border-danger-7 placeholder:text-danger-11/70 focus-visible:border-danger-8 bg-transparent',
    },
  },
});

const { class: className, resize, elevation, size, variant, ...props } = Astro.props;
---

<textarea
  data-slot="field-control"
  class={textareaVariants({ resize, elevation, size, variant, className })}
  {...props}
>
</textarea>
