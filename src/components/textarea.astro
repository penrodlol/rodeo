---
import { getComponentVariants } from '@/libs/variant';
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';

type Props = HTMLAttributes<'textarea'> & TextAreaVariants;

export type TextAreaVariants = VariantProps<typeof textareaVariants>;

export const textareaVariants = tv({
  extend: getComponentVariants().variants,
  slots: {
    base: [
      'w-full rounded px-4 py-2 select-none placeholder:text-current/50',
      'focus-visible:ring focus-visible:outline-none',
      'disabled:pointer-events-none disabled:opacity-50',
      'user-invalid:border-danger-7 user-invalid:focus-visible:border-danger-8',
    ],
  },
  defaultVariants: { resize: 'auto', size: '2', variant: 'gray-ghost-outline' },
  variants: {
    resize: { true: 'resize-y', false: 'resize-none', auto: 'field-sizing-content resize-none' },
    size: {
      '1': 'min-h-12 text-sm',
      '2': 'min-h-16 text-base',
      '3': 'min-h-20 text-lg',
      '4': 'min-h-24 text-xl',
      '5': 'min-h-28 text-2xl',
    },
  },
});

const { class: className, elevation, variant, resize, size, ...props } = Astro.props;
const slots = textareaVariants({ elevation, variant, resize, size });
---

<textarea data-slot="field-control" class={slots.base({ className })} {...props}></textarea>
