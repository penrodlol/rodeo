---
import type { HTMLTag, Polymorphic } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & SurfaceVariants;

export type SurfaceVariants = VariantProps<typeof surfaceVariants>;
export type SurfaceVariantsVariantKey = NonNullable<VariantProps<typeof surfaceVariantsVariant>['variant']>;

export const surfaceVariantsVariant = tv({
  variants: {
    variant: {
      'gray-surface': 'bg-gray-1',
      'gray-soft': 'bg-gray-2',
      'gray-surface-gradient': 'from-gray-1 to-gray-2 bg-linear-to-tr',
      'gray-soft-gradient': 'from-gray-2 to-gray-3 bg-linear-to-tr',
      'gray-surface-outline': 'bg-gray-1 border-gray-6 border',
      'gray-soft-outline': 'bg-gray-2 border-gray-6 border',
      'gray-surface-outline-gradient': 'from-gray-2 to-gray-3 border-gray-6 border bg-linear-to-tr',
      'gray-soft-outline-gradient': 'from-gray-2 to-gray-3 border-gray-6 border bg-linear-to-tr',
      'gray-ghost-outline': 'border-gray-6 border',
      'accent-surface': 'bg-accent-1',
      'accent-soft': 'bg-accent-2',
      'accent-surface-gradient': 'from-accent-1 to-accent-2 bg-linear-to-tr',
      'accent-soft-gradient': 'from-accent-2 to-accent-3 bg-linear-to-tr',
      'accent-surface-outline': 'bg-accent-1 border-accent-6 border',
      'accent-soft-outline': 'bg-accent-2 border-accent-6 border',
      'accent-surface-outline-gradient': 'from-accent-2 to-accent-3 border-accent-6 border bg-linear-to-tr',
      'accent-soft-outline-gradient': 'from-accent-2 to-accent-3 border-accent-6 border bg-linear-to-tr',
      'accent-ghost-outline': 'border-accent-6 border',
      'warn-surface': 'bg-warn-1',
      'warn-soft': 'bg-warn-2',
      'warn-surface-gradient': 'from-warn-1 to-warn-2 bg-linear-to-tr',
      'warn-soft-gradient': 'from-warn-2 to-warn-3 bg-linear-to-tr',
      'warn-surface-outline': 'bg-warn-1 border-warn-6 border',
      'warn-soft-outline': 'bg-warn-2 border-warn-6 border',
      'warn-surface-outline-gradient': 'from-warn-2 to-warn-3 border-warn-6 border bg-linear-to-tr',
      'warn-soft-outline-gradient': 'from-warn-2 to-warn-3 border-warn-6 border bg-linear-to-tr',
      'warn-ghost-outline': 'border-warn-6 border',
      'danger-surface': 'bg-danger-1',
      'danger-soft': 'bg-danger-2',
      'danger-surface-gradient': 'from-danger-1 to-danger-2 bg-linear-to-tr',
      'danger-soft-gradient': 'from-danger-2 to-danger-3 bg-linear-to-tr',
      'danger-surface-outline': 'bg-danger-1 border-danger-6 border',
      'danger-soft-outline': 'bg-danger-2 border-danger-6 border',
      'danger-surface-outline-gradient': 'from-danger-2 to-danger-3 border-danger-6 border bg-linear-to-tr',
      'danger-soft-outline-gradient': 'from-danger-2 to-danger-3 border-danger-6 border bg-linear-to-tr',
      'danger-ghost-outline': 'border-danger-6 border',
    },
  },
});

export const surfaceVariantsVariantKeysAll = Object.keys(surfaceVariantsVariant.variants.variant);
export const surfaceVariantsVariantKeys = {
  gray: surfaceVariantsVariantKeysAll.filter((key) => key.startsWith('gray-')) as Array<SurfaceVariantsVariantKey>,
  accent: surfaceVariantsVariantKeysAll.filter((key) => key.startsWith('accent-')) as Array<SurfaceVariantsVariantKey>,
  warn: surfaceVariantsVariantKeysAll.filter((key) => key.startsWith('warn-')) as Array<SurfaceVariantsVariantKey>,
  danger: surfaceVariantsVariantKeysAll.filter((key) => key.startsWith('danger-')) as Array<SurfaceVariantsVariantKey>,
};

export const surfaceVariants = tv({
  variants: {
    variant: surfaceVariantsVariant.variants.variant,
    rounded: { true: 'rounded' },
    elevation: { '1': 'elevation-1', '2': 'elevation-2', '3': 'elevation-3' },
    loading: {
      true: [
        'relative overflow-hidden before:absolute before:inset-x-0 before:-inset-y-full',
        'before:-translate-x-full before:rotate-4 before:rounded-[inherit]',
        'before:bg-linear-to-r before:from-transparent before:to-transparent',
        'before:motion-safe:motion-duration-2000 before:motion-safe:motion-ease-in-out',
        'before:motion-safe:motion-translate-x-loop-[200%]/reset',
      ],
    },
  },
  compoundVariants: [
    { loading: true, variant: surfaceVariantsVariantKeys.gray, class: 'before:via-gray-4' },
    { loading: true, variant: surfaceVariantsVariantKeys.accent, class: 'before:via-accent-4' },
    { loading: true, variant: surfaceVariantsVariantKeys.warn, class: 'before:via-warn-4' },
    { loading: true, variant: surfaceVariantsVariantKeys.danger, class: 'before:via-danger-4' },
  ],
});

const { as: Tag = 'div', class: className, variant, rounded, elevation, loading, ...props } = Astro.props;
---

<Tag class={surfaceVariants({ variant, rounded, elevation, loading, className })} {...props}><slot /></Tag>
