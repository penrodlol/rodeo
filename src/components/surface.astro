---
import type { HTMLTag, Polymorphic } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & SurfaceVariants;

export type SurfaceVariants = VariantProps<typeof surfaceVariants>;

export const surfaceVariants = tv({
  variants: {
    rounded: { true: 'rounded' },
    elevation: { '1': 'elevation-1', '2': 'elevation-2', '3': 'elevation-3' },
    variant: {
      'gray-surface': 'bg-gray-1',
      'gray-soft': 'bg-gray-2',
      'gray-surface-gradient': 'from-gray-1 to-gray-2 bg-linear-to-tr',
      'gray-soft-gradient': 'from-gray-2 to-gray-3 bg-linear-to-tr',
      'gray-surface-outline': 'bg-gray-1 border-gray-6 border',
      'gray-soft-outline': 'bg-gray-2 border-gray-6 border',
      'gray-surface-outline-gradient': 'from-gray-1 to-gray-2 border-gray-6 border bg-linear-to-tr',
      'gray-soft-outline-gradient': 'from-gray-2 to-gray-3 border-gray-6 border bg-linear-to-tr',
      'gray-ghost-outline': 'border-gray-6 border',
      'accent-surface': 'bg-accent-1',
      'accent-soft': 'bg-accent-2',
      'accent-surface-gradient': 'from-accent-1 to-accent-2 bg-linear-to-tr',
      'accent-soft-gradient': 'from-accent-2 to-accent-3 bg-linear-to-tr',
      'accent-surface-outline': 'bg-accent-1 border-accent-6 border',
      'accent-soft-outline': 'bg-accent-2 border-accent-6 border',
      'accent-surface-outline-gradient': 'from-accent-1 to-accent-2 border-accent-6 border bg-linear-to-tr',
      'accent-soft-outline-gradient': 'from-accent-2 to-accent-3 border-accent-6 border bg-linear-to-tr',
      'accent-ghost-outline': 'border-accent-6 border',
      'warn-surface': 'bg-warn-1',
      'warn-soft': 'bg-warn-2',
      'warn-surface-gradient': 'from-warn-1 to-warn-2 bg-linear-to-tr',
      'warn-soft-gradient': 'from-warn-2 to-warn-3 bg-linear-to-tr',
      'warn-surface-outline': 'bg-warn-1 border-warn-6 border',
      'warn-soft-outline': 'bg-warn-2 border-warn-6 border',
      'warn-surface-outline-gradient': 'from-warn-1 to-warn-2 border-warn-6 border bg-linear-to-tr',
      'warn-soft-outline-gradient': 'from-warn-2 to-warn-3 border-warn-6 border bg-linear-to-tr',
      'warn-ghost-outline': 'border-warn-6 border',
      'danger-surface': 'bg-danger-1',
      'danger-soft': 'bg-danger-2',
      'danger-surface-gradient': 'from-danger-1 to-danger-2 bg-linear-to-tr',
      'danger-soft-gradient': 'from-danger-2 to-danger-3 bg-linear-to-tr',
      'danger-surface-outline': 'bg-danger-1 border-danger-6 border',
      'danger-soft-outline': 'bg-danger-2 border-danger-6 border',
      'danger-surface-outline-gradient': 'from-danger-1 to-danger-2 border-danger-6 border bg-linear-to-tr',
      'danger-soft-outline-gradient': 'from-danger-2 to-danger-3 border-danger-6 border bg-linear-to-tr',
      'danger-ghost-outline': 'border-danger-6 border',
    },
  },
});

export function getSurfaceVariantKeys() {
  return Object.keys(surfaceVariants.variants.variant).reduce(
    (acc, key) => {
      if (key.startsWith('gray-')) (acc.gray ??= [])?.push(key);
      else if (key.startsWith('accent-')) (acc.accent ??= [])?.push(key);
      else if (key.startsWith('warn-')) (acc.warn ??= [])?.push(key);
      else if (key.startsWith('danger-')) (acc.danger ??= [])?.push(key);
      return acc;
      // https://github.com/heroui-inc/tailwind-variants/issues/185
    },
    {} as Record<'gray' | 'accent' | 'warn' | 'danger', any>,
  );
}

const { as: Tag = 'div', class: className, rounded, elevation, variant, ...props } = Astro.props;
---

<Tag class={surfaceVariants({ rounded, elevation, variant, className })} {...props}><slot /></Tag>
