---
import { getComponentVariants } from '@/libs/variant';
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';

type Props = HTMLAttributes<'input'> & InputVariants;

export type InputVariants = VariantProps<typeof inputVariants>;

export const inputVariants = tv({
  extend: getComponentVariants().variants,
  slots: {
    base: [
      'rounded px-4 select-none placeholder:text-current/50',
      'focus-visible:ring focus-visible:outline-none',
      'disabled:pointer-events-none disabled:opacity-50',
      'user-invalid:border-danger-7 user-invalid:focus-visible:border-danger-8',
    ],
  },
  defaultVariants: { size: '2', variant: 'gray-ghost-outline' },
  variants: {
    resize: { true: 'field-sizing-content max-w-full', false: 'w-full' },
    size: { '1': 'h-8 text-sm', '2': 'h-9 text-base', '3': 'h-10 text-lg', '4': 'h-11 text-xl', '5': 'h-12 text-2xl' },
  },
});

const { class: className, elevation, variant, resize, size, ...props } = Astro.props;
const slots = inputVariants({ elevation, variant, resize, size });
---

<input data-slot="field-control" class={slots.base({ className })} {...props} />
