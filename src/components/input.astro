---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';

type Props = HTMLAttributes<'input'> & InputVariants;

export type InputVariants = VariantProps<typeof inputVariants>;

export const inputVariants = tv({
  base: [
    'relative rounded border px-4 select-none',
    'focus-visible:outline-none disabled:pointer-events-none disabled:opacity-50',
    'user-invalid:border-danger-7 user-invalid:focus-visible:border-danger-8',
  ],
  defaultVariants: { size: '2', variant: 'gray-ghost-outline' },
  variants: {
    elevation: { '1': 'elevation-1', '2': 'elevation-2', '3': 'elevation-3' },
    size: { '1': 'h-8 text-sm', '2': 'h-9 text-base', '3': 'h-10 text-lg', '4': 'h-11 text-xl', '5': 'h-12 text-2xl' },
    // prettier-ignore
    variant: {
      'gray-surface': 'bg-gray-1 placeholder:text-gray-11/70 focus-visible:border-accent-8 border-transparent',
      'gray-ghost': 'border-transparent placeholder:text-gray-11/70 focus-visible:border-accent-8 bg-transparent',
      'gray-solid': 'bg-gray-9 placeholder:text-gray-contrast/70 focus-visible:border-accent-8 border-transparent',
      'gray-soft': 'bg-gray-3 placeholder:text-gray-11/70 focus-visible:border-accent-8 border-transparent',
      'gray-soft-outline': 'bg-gray-3 border-gray-7 placeholder:text-gray-11/70 focus-visible:border-accent-8',
      'gray-surface-outline': 'bg-gray-1 border-gray-7 placeholder:text-gray-11/70 focus-visible:border-accent-8',
      'gray-ghost-outline': 'border-gray-7 placeholder:text-gray-11/70 focus-visible:border-accent-8 bg-transparent',
      'accent-surface': 'bg-accent-1 placeholder:text-accent-11/70 focus-visible:border-accent-8 border-transparent',
      'accent-ghost': 'border-transparent placeholder:text-accent-11/70 focus-visible:border-accent-8 bg-transparent',
      'accent-solid': 'bg-accent-9 placeholder:text-accent-contrast/70 focus-visible:border-accent-8 border-transparent',
      'accent-soft': 'bg-accent-3 placeholder:text-accent-11/70 focus-visible:border-accent-8 border-transparent',
      'accent-soft-outline': 'bg-accent-3 border-accent-7 placeholder:text-accent-11/70 focus-visible:border-accent-8',
      'accent-surface-outline': 'bg-accent-1 border-accent-7 placeholder:text-accent-11/70 focus-visible:border-accent-8',
      'accent-ghost-outline': 'border-accent-7 placeholder:text-accent-11/70 focus-visible:border-accent-8 bg-transparent',
      'warn-surface': 'bg-warn-1 placeholder:text-warn-11/70 focus-visible:border-warn-8 border-transparent',
      'warn-ghost': 'border-transparent placeholder:text-warn-11/70 focus-visible:border-warn-8 bg-transparent',
      'warn-solid': 'bg-warn-9 placeholder:text-warn-contrast/70 focus-visible:border-warn-8 border-transparent',
      'warn-soft': 'bg-warn-3 placeholder:text-warn-11/70 focus-visible:border-warn-8 border-transparent',
      'warn-soft-outline': 'bg-warn-3 border-warn-7 placeholder:text-warn-11/70 focus-visible:border-warn-8',
      'warn-surface-outline': 'bg-warn-1 border-warn-7 placeholder:text-warn-11/70 focus-visible:border-warn-8',
      'warn-ghost-outline': 'border-warn-7 placeholder:text-warn-11/70 focus-visible:border-warn-8 bg-transparent',
      'danger-surface': 'bg-danger-1 placeholder:text-danger-11/70 focus-visible:border-danger-8 border-transparent',
      'danger-ghost': 'border-transparent placeholder:text-danger-11/70 focus-visible:border-danger-8 bg-transparent',
      'danger-solid': 'bg-danger-9 placeholder:text-danger-contrast/70 focus-visible:border-danger-8 border-transparent',
      'danger-soft': 'bg-danger-3 placeholder:text-danger-11/70 focus-visible:border-danger-8 border-transparent',
      'danger-soft-outline': 'bg-danger-3 border-danger-7 placeholder:text-danger-11/70 focus-visible:border-danger-8',
      'danger-surface-outline': 'bg-danger-1 border-danger-7 placeholder:text-danger-11/70 focus-visible:border-danger-8',
      'danger-ghost-outline': 'border-danger-7 placeholder:text-danger-11/70 focus-visible:border-danger-8 bg-transparent',
    },
  },
});

const { class: className, elevation, size, variant, ...props } = Astro.props;
---

<input data-slot="field-control" class={inputVariants({ elevation, size, variant, className })} {...props} />
