---
import Separator from '@/components/separator.astro';
import Surface from '@/components/surface.astro';
import Layout from '@/layouts/index.astro';
---

<Layout>
  <Surface class="flex flex-col gap-12">
    <Surface class="flex flex-col gap-6">
      <Separator orientation="horizontal" variant="gray" />
      <Separator orientation="horizontal" variant="accent" />
      <Separator orientation="horizontal" variant="warn" />
      <Separator orientation="horizontal" variant="danger" />
    </Surface>
    <Surface class="flex gap-6 *:h-60">
      <Separator orientation="vertical" variant="gray" />
      <Separator orientation="vertical" variant="accent" />
      <Separator orientation="vertical" variant="warn" />
      <Separator orientation="vertical" variant="danger" />
    </Surface>
  </Surface>
</Layout>
