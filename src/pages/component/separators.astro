---
import Separator from '@/components/separator.astro';
import Surface from '@/components/surface.astro';
import Layout from '@/layouts/index.astro';
---

<Layout>
  <Surface class="flex flex-col gap-6">
    <Surface class="flex flex-col gap-6">
      <Separator orientation="horizontal" class="lg:w-1/3" />
      <Separator orientation="horizontal" class="lg:w-1/2" />
      <Separator orientation="horizontal" />
    </Surface>
    <Surface class="flex items-end gap-6">
      <Separator orientation="vertical" class="h-24" />
      <Separator orientation="vertical" class="h-32" />
      <Separator orientation="vertical" class="h-40" />
    </Surface>
  </Surface>
</Layout>
