      <Switch variant="danger-soft-outline" textVariants={{ variant: 'danger' }}>Enable notifications</Switch>
    </Surface>
    <Surface class="mb-12 flex flex-wrap gap-6">
      <Switch variant="gray-soft-outline" disabled>Enable notifications</Switch>
      <Switch variant="gray-accent-soft-outline" disabled>Enable notifications</Switch>
      <Switch variant="accent-soft-outline" textVariants={{ variant: 'accent' }} disabled>Enable notifications</Switch>
      <Switch variant="warn-soft-outline" textVariants={{ variant: 'warn' }} disabled>Enable notifications</Switch>
      <Switch variant="danger-soft-outline" textVariants={{ variant: 'danger' }} disabled>Enable notifications</Switch>
