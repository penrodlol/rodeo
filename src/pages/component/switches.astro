      <Fieldset.Root>
        <Fieldset.Legend>Notification Settings</Fieldset.Legend>
        <Fieldset.Controls class="*:w-60 *:justify-between">
          <Switch>Enable notifications</Switch>
          <Switch>Enable marketing emails</Switch>
          <Switch>Enable SMS alerts</Switch>
        </Fieldset.Controls>
      </Fieldset.Root>
      <Fieldset.Root>
        <Fieldset.Legend>Notification Settings</Fieldset.Legend>
        <Fieldset.Controls class="*:*:w-60 *:*:justify-between">
          <Field.Root>
            <Switch>Enable notifications</Switch>
            <Field.Description>Receive email notification updates</Field.Description>
          </Field.Root>
          <Field.Root>
            <Switch>Enable marketing emails</Switch>
            <Field.Description>Get the latest news and offers</Field.Description>
          </Field.Root>
          <Field.Root>
            <Switch>Enable SMS alerts</Switch>
            <Field.Description>Receive important alerts via SMS</Field.Description>
          </Field.Root>
        </Fieldset.Controls>
      </Fieldset.Root>
      <Fieldset.Root>
        <Fieldset.Legend>Notification Settings</Fieldset.Legend>
        <Fieldset.Description>Manage your notification preferences below</Fieldset.Description>
