---
import Spinner from '@/components/spinner.astro';
import Surface from '@/components/surface.astro';
import Layout from '@/layouts/index.astro';
---

<Layout>
  <Surface class="flex flex-col items-center gap-6">
    <Surface class="flex flex-wrap gap-6">
      <Spinner />
      <Spinner variant="soft" />
      <Spinner variant="accent" />
      <Spinner variant="warn" />
      <Spinner variant="danger" />
    </Surface>
    <Surface class="flex flex-wrap items-end gap-6">
      <Spinner size="1" />
      <Spinner size="2" />
      <Spinner size="3" />
      <Spinner size="4" />
      <Spinner size="5" />
    </Surface>
    <Surface class="flex flex-wrap gap-6">
      <Spinner name="loader-circle" />
      <Spinner name="loader-pinwheel" />
      <Spinner name="shell" />
    </Surface>
  </Surface>
</Layout>
