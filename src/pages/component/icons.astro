---
import Icon from '@/components/icon.astro';
import Surface from '@/components/surface.astro';
import Layout from '@/layouts/index.astro';
---

<Layout>
  <Surface class="flex flex-col items-center gap-6 self-center">
    <Surface class="flex flex-wrap items-end gap-6">
      <Icon name="sparkles" variant="soft" />
      <Icon name="sparkles" variant="accent" />
      <Icon name="sparkles" variant="warn" />
      <Icon name="sparkles" variant="danger" />
    </Surface>
    <Surface class="flex flex-wrap items-end gap-6">
      <Icon name="sparkles" size="1" />
      <Icon name="sparkles" size="2" />
      <Icon name="sparkles" size="3" />
      <Icon name="sparkles" size="4" />
      <Icon name="sparkles" size="5" />
    </Surface>
  </Surface>
</Layout>
